---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Glorious Hearts">
  <main>
    <section class="hero">
      <img class="hero-badge" src="/favicon.png" alt="" />

      <div class="hero-inner">
        <d class="hero-topline">
          <div class="kicker">Heart of Midlothian • 2025/26</div>
        </d>
        <h1>A Season To Remember</h1>

        <h2>A celebration of an amazing team during an amazing season.</h2>
        <h2>
          Match reports, highlights, photos from a season where we came so
          close.
        </h2>
        <h2>We'll be back. Bigger and Stronger <strong>HHGH</strong></h2>

        <div class="stats home-stats">
          <a href="/matches" class="stat home-stat-link">
            <span class="home-stat-icon">⚽</span>
            The<strong>Matches</strong>
          </a>

          <a href="/team" class="stat home-stat-link">
            <span class="home-stat-icon">👥</span>
            The<strong>Players</strong>
          </a>

          <div class="stat home-stat-muted">
            <span class="home-stat-icon">★</span>
            The<strong>Story</strong>
          </div>
        </div>
      </div>
    </section>

    <section class="frontpage-photo">
      <img src="/images/frontpage.webp" alt="Hearts players celebrating" />
    </section>
  </main>
</BaseLayout>
