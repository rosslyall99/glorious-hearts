---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { players } from "../../data/players.js";

export function getStaticPaths() {
  return players.map((player) => ({
    params: { slug: player.slug },
    props: { player },
  }));
}

const { player } = Astro.props;
---

<BaseLayout title={`${player.name} | Hearts 2025/26`}>
  <section class="hero player-hero">
    <img class="hero-badge" src="/favicon.png" alt="" />

    <div class="hero-inner">
      <div class="hero-topline">
        <a href="/team" class="hero-nav-link">← Back to players</a>
        <div>Heart of Midlothian • 2025/26</div>
      </div>

      <h1>{player.name}</h1>

      <div class="stats player-profile-stats">
        <div class="stat">
          <span>Squad number</span>
          <strong>{player.squadNumber}</strong>
        </div>

        <div class="stat">
          <span>Position</span>
          <strong>{player.position}</strong>
        </div>

        <div class="stat">
          <span>Age</span>
          <strong>{player.age}</strong>
        </div>

        <div class="stat">
          <span>Height</span>
          <strong>{player.height}</strong>
        </div>
      </div>
    </div>
  </section>

  <main class="shell player-detail-layout">
    <section class="player-detail-main">
      <div class="panel">
        <div class="section-heading">
          <span>Player</span>
        </div>
        <div class="detail-grid">
          <div>
            <span>Joined</span>
            <strong>{player.joined}</strong>
          </div>

          <div>
            <span>Contract until</span>
            <strong>{player.contractUntil}</strong>
          </div>

          <div>
            <span>Market value</span>
            <strong>{player.marketValue}</strong>
          </div>
        </div>
      </div>

      <div class="panel">
        <div class="section-heading">
          <span>Season</span>
        </div>
        <div class="season-grid">
          <div>
            <span>Appearances</span><strong>{player.appearances}</strong>
          </div>
          <div><span>In squad</span><strong>{player.inSquad}</strong></div>
          <div>
            <span>Minutes played</span><strong>{player.minutes}</strong>
          </div>

          <div><span>Goals</span><strong>{player.goals}</strong></div>
          <div><span>Assists</span><strong>{player.assists}</strong></div>
          <div class="season-empty"></div>

          <div>
            <span>Yellow cards</span><strong>{player.yellowCards}</strong>
          </div>
          <div>
            <span>Second yellows</span><strong>{player.secondYellow}</strong>
          </div>
          <div><span>Red cards</span><strong>{player.redCards}</strong></div>

          <div><span>Subbed on</span><strong>{player.subbedOn}</strong></div>
          <div><span>Subbed off</span><strong>{player.subbedOff}</strong></div>
          <div class="season-empty"></div>
        </div>
      </div>

      <div class="panel">
        <div class="section-heading">
          <span>Bio</span>
        </div>
        <div class="summary-text" set:html={player.bio || "Bio to be added."} />
      </div>
    </section>

    <aside class="player-image-wrap">
      <div class="player-image-card">
        <img src={player.fullImage} alt={player.name} />
      </div>

      <div class="player-image-mini" aria-hidden="true">
        <img src={player.fullImage} alt="" />
      </div>
    </aside>

    <script>
      const imageWrapEl = document.querySelector(".player-image-wrap");
      const miniImageEl = document.querySelector(".player-image-mini");

      if (
        imageWrapEl instanceof HTMLElement &&
        miniImageEl instanceof HTMLElement
      ) {
        const imageWrap = imageWrapEl;
        const miniImage = miniImageEl;

        function updateMiniImage() {
          if (window.innerWidth > 768) {
            miniImage.classList.remove("is-visible");
            return;
          }

          const shouldShow =
            window.scrollY > imageWrap.offsetTop + imageWrap.offsetHeight;

          miniImage.classList.toggle("is-visible", shouldShow);
        }

        window.addEventListener("scroll", updateMiniImage, { passive: true });
        window.addEventListener("resize", updateMiniImage);
        updateMiniImage();
      }
    </script>
  </main>
</BaseLayout>
