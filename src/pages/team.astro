---
import BaseLayout from "../layouts/BaseLayout.astro";

type Position = "goalkeepers" | "defenders" | "midfielders" | "forwards";

type Player = {
  name: string;
  position: Position;
  src: string;
};

const playerImages = import.meta.glob<string>(
  "/public/images/players/{goalkeepers,defenders,midfielders,forwards}/head/*.{png,jpg,jpeg,webp}",
  { eager: true, query: "?url", import: "default" },
);

const positionOrder: Position[] = [
  "goalkeepers",
  "defenders",
  "midfielders",
  "forwards",
];

const positionLabels: Record<Position, string> = {
  goalkeepers: "Goalkeepers",
  defenders: "Defenders",
  midfielders: "Midfielders",
  forwards: "Forwards",
};

const cleanName = (filePath: string) => {
  const file = filePath.split("/").pop() || "";

  return file
    .replace(/\.(png|jpg|jpeg|webp)$/i, "")
    .replace(/[-_]/g, " ")
    .replace(/\b\w/g, (char: string) => char.toUpperCase());
};

const isPosition = (value: string): value is Position => {
  return positionOrder.includes(value as Position);
};

const players: Player[] = Object.entries(playerImages)
  .map(([path, src]) => {
    const possiblePosition = path.split("/")[4];

    if (!isPosition(possiblePosition)) {
      return null;
    }

    return {
      name: cleanName(path),
      position: possiblePosition,
      src: src.replace("/public", ""),
    };
  })
  .filter((player): player is Player => player !== null);

const playersByPosition = positionOrder.map((position) => ({
  position,
  label: positionLabels[position],
  players: players
    .filter((player) => player.position === position)
    .sort((a, b) => {
      const surnameA = a.name.split(" ").pop() ?? "";
      const surnameB = b.name.split(" ").pop() ?? "";

      return surnameA.localeCompare(surnameB);
    }),
}));
---

<BaseLayout title="The Players | Hearts 2025/26">
  <section class="hero">
    <img class="hero-badge" src="/favicon.png" alt="" />

    <div class="hero-inner">
      <div class="hero-topline">
        <a href="/" class="hero-nav-link">← Home</a>
        <div>Heart of Midlothian • 2025/26</div>
      </div>

      <h1>The Players</h1>
      <h2>A talented squad built around a strong Scottish core.</h2>
      <h2>
        Jamestown Analytics helped bring in an exciting new wave of exciting
        signings.
      </h2>
      <h2>
        With McInnes’ experience and Bloom’s backing, it feels a great time to
        be a Jambo.
      </h2>

      <div class="stats player-stats" aria-label="Player positions">
        {
          playersByPosition.map((group) => (
            <a href={`#${group.position}`} class="stat position-stat">
              <strong>{group.label}</strong>
              <span>{group.players.length}</span>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <main class="shell">
    <section class="players-wall">
      {
        playersByPosition.map((group) => (
          <section class="position-section" id={group.position}>
            <div class="section-heading">
              <span>{group.label}</span>
              <small>
                <a href="#top" class="back-to-top">
                  Back to top ↑
                </a>
              </small>
            </div>

            <div class="masonry-grid">
              {group.players.map((player, index) => (
                <a
                  class="player-card"
                  href={`/players/${player.name.toLowerCase().replaceAll(" ", "-")}/`}
                >
                  <div class="maroon-angle" />

                  <img src={player.src} alt={player.name} loading="lazy" />

                  <div class="player-info">
                    <p>{positionLabels[player.position]}</p>
                    <h2>{player.name}</h2>
                  </div>
                </a>
              ))}
            </div>
          </section>
        ))
      }
    </section>
  </main>
</BaseLayout>
